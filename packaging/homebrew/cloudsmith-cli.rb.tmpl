class CloudsmithCli < Formula
  desc "Official Cloudsmith Command-Line Interface"
  homepage "https://docs.cloudsmith.com/developer-tools/cli"
  version "__VERSION__"
  license "Apache-2.0"

  if OS.mac? && Hardware::CPU.arm?
    url "https://dl.cloudsmith.io/public/__NAMESPACE__/__REPO__/raw/names/cloudsmith-cli-macos-arm64/versions/__VERSION__/cloudsmith-__VERSION__-macos-arm64.tar.gz"
    sha256 "__SHA256_MACOS_ARM64__"
  elsif OS.mac? && Hardware::CPU.intel?
    url "https://dl.cloudsmith.io/public/__NAMESPACE__/__REPO__/raw/names/cloudsmith-cli-macos-x86_64/versions/__VERSION__/cloudsmith-__VERSION__-macos-x86_64.tar.gz"
    sha256 "__SHA256_MACOS_X86_64__"
  elsif OS.linux? && Hardware::CPU.arm? && Hardware::CPU.is_64_bit?
    url "https://dl.cloudsmith.io/public/__NAMESPACE__/__REPO__/raw/names/cloudsmith-cli-linux-aarch64-gnu/versions/__VERSION__/cloudsmith-__VERSION__-linux-aarch64-gnu.tar.gz"
    sha256 "__SHA256_LINUX_AARCH64_GNU__"
  elsif OS.linux? && Hardware::CPU.intel? && Hardware::CPU.is_64_bit?
    url "https://dl.cloudsmith.io/public/__NAMESPACE__/__REPO__/raw/names/cloudsmith-cli-linux-x86_64-gnu/versions/__VERSION__/cloudsmith-__VERSION__-linux-x86_64-gnu.tar.gz"
    sha256 "__SHA256_LINUX_X86_64_GNU__"
  end

  # Placed after the url stanzas: a leading livecheck url is misdetected as the
  # stable url by audit when every real url is inside a conditional.
  livecheck do
    url "https://dl.cloudsmith.io/public/__NAMESPACE__/__REPO__/raw/names/cloudsmith-cli-manifest-macos-arm64/versions/latest/manifest.txt"
    regex(/^version=(\d+(?:\.\d+)+)$/i)
  end

  def install
    # PyInstaller onedir bundle: the executable must stay next to _internal/.
    libexec.install Dir["*"]
    bin.write_exec_script libexec/"cloudsmith"
  end

  test do
    assert_match "CLI Package Version: #{version}", shell_output("#{bin}/cloudsmith --version")
  end
end
